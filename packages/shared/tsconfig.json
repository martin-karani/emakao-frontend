{
    "$schema": "https://json.schemastore.org/tsconfig",
    "compilerOptions": {
      "target": "ES2022",
      "lib": ["ES2022"],
      "module": "ESNext",
      "moduleResolution": "Bundler",
      "strict": true,
      "noUncheckedIndexedAccess": true,
      "skipLibCheck": true,
      "declaration": true,
      "declarationMap": true,
      "isolatedModules": true,
      "noEmit": true
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules"]
  }